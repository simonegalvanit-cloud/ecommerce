NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (used in Stripe return_url and emails)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Admin panel credentials (server-side only — never exposed to the browser)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASS=your-secure-password-here
ADMIN_NAME=Your Name
# Random secret used for the admin session cookie — generate with: openssl rand -hex 32
ADMIN_SESSION_TOKEN=your-random-secret-here

# Resend (email service) — get your key at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Verified sender address in Resend (must match your verified domain)
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Email address to receive new order notifications
CONTACT_TO_EMAIL=admin@yourdomain.com

# Stripe — get your keys at dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Stripe webhook: listen to payment_intent.succeeded, payment_intent.payment_failed, charge.refunded
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
